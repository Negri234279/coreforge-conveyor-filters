# STAGING stack env (app + SigNoz backend, single compose).
# Copy to `.env` (gitignored) and fill in the required values below.
#
# Sibling .env.example files in infra/{dev,prod}/ — keep their JWT secrets
# distinct so a compromised staging token can't sign prod sessions.

# ── SigNoz backend ──────────────────────────────────────────────────────

# Required: secret for SigNoz session/JWT signing. Generate with:
#   openssl rand -base64 48
SIGNOZ_TOKENIZER_JWT_SECRET=

# Optional image pins. Mirror these from infra/prod/.env so staging
# reproduces prod's exact SigNoz/collector versions.
SIGNOZ_TAG=v0.122.0
OTELCOL_TAG=v0.144.4

# Bind address for the SigNoz UI on host port 3302. Loopback by default;
# flip to 0.0.0.0 if NPM at 192.168.1.7 proxies signoz.staging.<domain>
# to 192.168.1.11:3302.
SIGNOZ_UI_BIND=127.0.0.1

# Bind address for the OTLP HTTP receiver on host port 4320. Defaults to
# 0.0.0.0 because NPM has to reach it from another machine (the RPi).
STAGING_OTLP_HTTP_BIND=0.0.0.0

# ── App ─────────────────────────────────────────────────────────────────

# Bind address for the app's published port 8081. Defaults to 0.0.0.0 so
# NPM can reach it via the host IP. Use 127.0.0.1 to keep it local.
STAGING_BIND=0.0.0.0

# Browser RUM endpoint. Leave commented to disable RUM in staging (backend
# OTel still works). Set when NPM is wired for the otlp.staging.* host.
# OTEL_RUM_EXPORTER_URL=https://otlp.staging.coreforge-conveyor-filters.negri.es

# Admin "SigNoz" button URL. Defaults to http://127.0.0.1:3302.
# SIGNOZ_URL=https://signoz.staging.coreforge-conveyor-filters.negri.es
