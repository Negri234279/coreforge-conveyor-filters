{
    "title": "CoreForge — App Health",
    "description": "Salud técnica: tasa y latencia de requests, errores recientes (backend + RUM del navegador). Complementa la pestaña Services nativa de SigNoz con la vista filtrada solo a coreforge*.",
    "tags": ["coreforge", "ops"],
    "version": "v4",
    "panelMap": {},
    "variables": {
        "service-var": {
            "id": "service-var",
            "name": "service.name",
            "description": "Servicio (coreforge en prod, coreforge-dev en dev, coreforge-web* para RUM).",
            "type": "QUERY",
            "queryValue": "SELECT JSONExtractString(labels, 'service.name') AS `service.name` FROM signoz_metrics.time_series_v4_1day WHERE (metric_name = 'signoz_calls_total') AND (unix_milli >= (toUnixTimestamp(now() - toIntervalDay(7)) * 1000)) AND `service.name` LIKE 'coreforge%' GROUP BY `service.name`",
            "multiSelect": true,
            "showALLOption": true,
            "allSelected": true,
            "sort": "ASC",
            "modificationUUID": "var-mod-1",
            "order": 0,
            "customValue": "",
            "textboxValue": ""
        }
    },
    "layout": [
        { "i": "panel-req-rate", "x": 0, "y": 0, "w": 6, "h": 6, "moved": false, "static": false },
        { "i": "panel-p95", "x": 6, "y": 0, "w": 6, "h": 6, "moved": false, "static": false },
        { "i": "panel-errors-by-type", "x": 0, "y": 6, "w": 6, "h": 6, "moved": false, "static": false },
        { "i": "panel-recent-errors", "x": 6, "y": 6, "w": 6, "h": 6, "moved": false, "static": false }
    ],
    "widgets": [
        {
            "id": "panel-req-rate",
            "title": "Requests/min por ruta",
            "description": "Tasa de requests servidos por ruta HTTP (auto-instrumentación de Node).",
            "panelTypes": "graph",
            "fillSpans": false,
            "isStacked": false,
            "nullZeroValues": "zero",
            "opacity": "1",
            "yAxisUnit": "short",
            "query": {
                "queryType": "builder",
                "builder": {
                    "queryData": [
                        {
                            "queryName": "A",
                            "expression": "A",
                            "dataSource": "traces",
                            "aggregateOperator": "rate",
                            "aggregateAttribute": {
                                "key": "name",
                                "dataType": "string",
                                "type": "tag",
                                "isColumn": true,
                                "isJSON": false,
                                "id": "name--string--tag--true"
                            },
                            "filters": {
                                "op": "AND",
                                "items": [
                                    {
                                        "id": "f1",
                                        "key": {
                                            "key": "serviceName",
                                            "dataType": "string",
                                            "type": "tag",
                                            "isColumn": true,
                                            "isJSON": false,
                                            "id": "serviceName--string--tag--true"
                                        },
                                        "op": "in",
                                        "value": ["{{.service.name}}"]
                                    },
                                    {
                                        "id": "f2",
                                        "key": {
                                            "key": "spanKind",
                                            "dataType": "string",
                                            "type": "tag",
                                            "isColumn": true,
                                            "isJSON": false,
                                            "id": "spanKind--string--tag--true"
                                        },
                                        "op": "=",
                                        "value": "Server"
                                    }
                                ]
                            },
                            "groupBy": [
                                {
                                    "key": "httpRoute",
                                    "dataType": "string",
                                    "type": "tag",
                                    "isColumn": true,
                                    "isJSON": false,
                                    "id": "httpRoute--string--tag--true"
                                }
                            ],
                            "having": [],
                            "orderBy": [],
                            "legend": "{{httpRoute}}",
                            "stepInterval": 60,
                            "timeAggregation": "rate",
                            "spaceAggregation": "sum",
                            "functions": [],
                            "disabled": false,
                            "limit": 20,
                            "reduceTo": "sum"
                        }
                    ],
                    "queryFormulas": []
                },
                "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
                "clickhouse_sql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
                "id": "q-req-rate"
            }
        },
