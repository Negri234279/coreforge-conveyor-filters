{
    "title": "CoreForge — Business Events",
    "description": "Eventos de negocio emitidos desde lib/events.ts (filter_create, category_clone, user_login, etc.). Cada panel filtra por el atributo `app.event.type` que pone logEvent() en cada log.",
    "tags": ["coreforge", "product"],
    "version": "v4",
    "panelMap": {},
    "variables": {
        "service-var": {
            "id": "service-var",
            "name": "service.name",
            "description": "Servicio (coreforge en prod, coreforge-dev en dev).",
            "type": "QUERY",
            "queryValue": "SELECT DISTINCT resources_string['service.name'] AS `service.name` FROM signoz_logs.distributed_logs_v2 WHERE timestamp >= toUInt64(toUnixTimestamp(now() - toIntervalDay(7))) * 1000000000 AND resources_string['service.name'] LIKE 'coreforge%' ORDER BY `service.name`",
            "multiSelect": false,
            "showALLOption": true,
            "allSelected": true,
            "sort": "ASC",
            "modificationUUID": "var-mod-1",
            "order": 0,
            "customValue": "",
            "textboxValue": ""
        }
    },
    "layout": [
        { "i": "panel-events-rate", "x": 0, "y": 0, "w": 8, "h": 6, "moved": false, "static": false },
        { "i": "panel-events-totals", "x": 8, "y": 0, "w": 4, "h": 6, "moved": false, "static": false },
        { "i": "panel-top-users", "x": 0, "y": 6, "w": 6, "h": 6, "moved": false, "static": false },
        { "i": "panel-recent-events", "x": 6, "y": 6, "w": 6, "h": 6, "moved": false, "static": false }
