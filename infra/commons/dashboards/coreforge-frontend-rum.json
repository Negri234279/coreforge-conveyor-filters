{
    "title": "CoreForge — Frontend RUM",
    "description": "Browser Real User Monitoring: page loads, navegación y errores JS desde el SDK web (src/otel-web/init.ts). Acotado a los servicios coreforge-web*.",
    "tags": ["coreforge", "rum", "frontend"],
    "version": "v4",
    "panelMap": {},
    "variables": {
        "service-var": {
            "id": "service-var",
            "name": "service.name",
            "description": "Servicio web (coreforge-web en prod, coreforge-web-dev en dev).",
            "type": "QUERY",
            "queryValue": "SELECT DISTINCT resources_string['service.name'] AS `service.name` FROM signoz_logs.distributed_logs_v2 WHERE timestamp >= toUInt64(toUnixTimestamp(now() - toIntervalDay(7))) * 1000000000 AND resources_string['service.name'] LIKE 'coreforge-web%' ORDER BY `service.name`",
            "multiSelect": true,
            "showALLOption": true,
            "allSelected": true,
            "sort": "ASC",
            "modificationUUID": "var-mod-1",
            "order": 0,
            "customValue": "",
            "textboxValue": ""
        }
    },
    "layout": [
        { "i": "panel-pageviews", "x": 0, "y": 0, "w": 8, "h": 6, "moved": false, "static": false },
        { "i": "panel-top-pages", "x": 8, "y": 0, "w": 4, "h": 6, "moved": false, "static": false },
        { "i": "panel-errors-rate", "x": 0, "y": 6, "w": 6, "h": 6, "moved": false, "static": false },
        { "i": "panel-recent-errors", "x": 6, "y": 6, "w": 6, "h": 6, "moved": false, "static": false }
    ],
    "widgets": [
        {
            "id": "panel-pageviews",
            "title": "Page loads / min",
            "description": "Conteo de spans `documentLoad` emitidos por @opentelemetry/instrumentation-document-load — un span por carga de página completa.",
            "panelTypes": "graph",
            "fillSpans": false,
            "isStacked": false,
            "nullZeroValues": "zero",
            "opacity": "1",
            "yAxisUnit": "short",
            "query": {
                "queryType": "builder",
                "builder": {
                    "queryData": [
                        {
                            "queryName": "A",
                            "expression": "A",
                            "dataSource": "traces",
                            "aggregateOperator": "count",
                            "aggregateAttribute": {
                                "key": "name",
                                "dataType": "string",
                                "type": "tag",
                                "isColumn": true,
                                "isJSON": false,
                                "id": "name--string--tag--true"
                            },
                            "filters": {
                                "op": "AND",
                                "items": [
                                    {
                                        "id": "f1",
                                        "key": {
                                            "key": "serviceName",
                                            "dataType": "string",
                                            "type": "tag",
                                            "isColumn": true,
                                            "isJSON": false,
                                            "id": "serviceName--string--tag--true"
                                        },
                                        "op": "in",
                                        "value": ["{{.service.name}}"]
                                    },
                                    {
                                        "id": "f2",
                                        "key": {
                                            "key": "name",
                                            "dataType": "string",
                                            "type": "tag",
                                            "isColumn": true,
                                            "isJSON": false,
                                            "id": "name--string--tag--true"
                                        },
                                        "op": "=",
                                        "value": "documentLoad"
                                    }
                                ]
                            },
                            "groupBy": [],
                            "having": [],
                            "orderBy": [],
                            "legend": "loads",
                            "stepInterval": 60,
                            "timeAggregation": "rate",
                            "spaceAggregation": "sum",
                            "functions": [],
                            "disabled": false,
                            "limit": null,
                            "reduceTo": "sum"
                        }
                    ],
                    "queryFormulas": []
                },
                "promql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
                "clickhouse_sql": [{ "name": "A", "query": "", "legend": "", "disabled": false }],
                "id": "q-pageviews"
            }
        },
