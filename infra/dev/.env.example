# DEVELOPMENT SigNoz stack env. Copy to .env if you want to override the
# defaults. .env is gitignored. The dev compose has safe inline fallbacks,
# so a missing .env is fine — only set this if you need to deviate.
#
# Sibling .env.example files in infra/{prod,staging}/ — keep their JWT
# secrets distinct.

# Optional: secret for SigNoz session/JWT signing. The dev compose ships
# with a hardcoded fallback ("local-only-not-a-secret-change-me") so the
# stack boots without a .env. Set this only if you publish the dev UI to
# anywhere reachable from another machine. Generate with:
#   openssl rand -base64 48
SIGNOZ_TOKENIZER_JWT_SECRET=

# Optional image pins. Match these to prod's pins when reproducing an
# incident locally; otherwise leave at the compose defaults.
SIGNOZ_TAG=v0.122.0
OTELCOL_TAG=v0.144.4

# Bind address for the SigNoz UI. Loopback by default — flip to 0.0.0.0
# only if you proxy signoz-dev.<domain> through NPM on the RPi.
SIGNOZ_UI_BIND=127.0.0.1
