# PRODUCTION SigNoz stack env. Copy to .env and fill in. .env is gitignored.
# Sibling .env.example files in infra/{dev,staging}/ — keep their JWT
# secrets distinct so a leaked dev token can't sign prod sessions.

# Required: secret for SigNoz session/JWT signing. Generate with:
#   openssl rand -base64 48
SIGNOZ_TOKENIZER_JWT_SECRET=

# Optional image pins. Bump to test upgrades.
SIGNOZ_TAG=v0.122.0
OTELCOL_TAG=v0.144.4

# Bind addresses for the host-published ports. Defaults expose on every
# interface so an external reverse proxy (e.g. NPM in its own container) can
# reach them. If NPM lives on this host and you've put SigNoz + NPM on a
# shared docker network, restrict these to 127.0.0.1.
SIGNOZ_UI_BIND=0.0.0.0
OTLP_HTTP_BIND=0.0.0.0
