---
import '../styles/global.css'

interface Props {
    title?: string
    /** Meta description / OG description for this page. */
    description?: string
    /** OG/Twitter preview image, resolved against the site origin. */
    image?: string
    /** Set true on pages that shouldn't be indexed (auth, account…). */
    noindex?: boolean
    activeNav?: 'home' | 'new' | 'org' | 'orgFilters' | 'account'
    /** Hide the nav (used on the auth pages). */
    hideNav?: boolean
}

const SITE_NAME = 'CoreForge — Conveyor Filters'
const DEFAULT_DESCRIPTION =
    'Design, organise and share Rust industrial conveyor filter presets. Build presets in your browser and copy/paste the exact JSON the game expects.'

const {
    title = SITE_NAME,
    description = DEFAULT_DESCRIPTION,
    image = '/og-image.png',
    noindex = false,
    activeNav = 'home',
    hideNav = false,
} = Astro.props

// Astro.site is set in astro.config.mjs; fall back to the request origin in dev.
const siteOrigin = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin)
const ogImageUrl = new URL(image, siteOrigin)
const user = Astro.locals.user
// Only the bits the UI needs — keeps the email server-side.
const clientUser = user
    ? {
          id: user.id,
          username: user.username,
          orgId: user.orgId ?? null,
          orgRole: user.orgRole ?? null,
      }
    : null
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl.href} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}
        <meta name="theme-color" content="#0d1117" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content={SITE_NAME} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl.href} />
        <meta property="og:image" content={ogImageUrl.href} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:locale" content="en" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl.href} />

        <script is:inline define:vars={{ clientUser }}>
            window.__cf_user = clientUser
        </script>
    </head>
    <body
        class="min-h-full bg-[#0d1117] font-sans text-slate-200 antialiased"
        style="font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif"
    >
        <div class="flex min-h-screen flex-col">
            <header
                class="sticky top-0 z-30 border-b border-slate-800/80 bg-[#0d1117]/95 backdrop-blur"
            >
                <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4">
                    <a
                        href={user ? '/' : '/login'}
                        class="flex items-center gap-2 text-sm font-bold tracking-[0.18em] text-slate-100 uppercase"
                    >
                        <span
                            class="inline-block h-2 w-2 rounded-full bg-teal-400 shadow-[0_0_10px_rgba(45,212,191,0.7)]"
                        ></span>
                        CoreForge
                        <span class="text-xs font-normal tracking-normal text-slate-400 normal-case"
                            >· Conveyor Filters</span
                        >
                    </a>

                    {
                        !hideNav && user ? (
                            <nav class="flex flex-wrap items-center gap-1 text-sm">
                                <a
                                    href="/"
                                    class:list={[
                                        'rounded px-3 py-1.5',
                                        activeNav === 'home'
                                            ? 'bg-slate-800 text-slate-100'
                                            : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                                    ]}
                                >
                                    My Conveyors
                                </a>
                                <a
                                    href="/org/filters"
                                    class:list={[
                                        'rounded px-3 py-1.5',
                                        activeNav === 'orgFilters'
                                            ? 'bg-slate-800 text-slate-100'
                                            : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                                    ]}
                                >
                                    Clan Filters
                                </a>
                                <a
                                    href="/org"
                                    class:list={[
                                        'rounded px-3 py-1.5',
                                        activeNav === 'org'
                                            ? 'bg-slate-800 text-slate-100'
                                            : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                                    ]}
                                >
                                    Clan
                                </a>
                                <a
                                    href="/filters/new"
                                    class:list={[
                                        'rounded px-3 py-1.5 font-semibold',
                                        activeNav === 'new'
                                            ? 'bg-teal-500/90 text-slate-950'
                                            : 'bg-teal-500/80 text-slate-950 hover:bg-teal-400',
                                    ]}
                                >
                                    + New Filter
                                </a>
                                <div class="ml-2 flex items-center gap-2 border-l border-slate-800 pl-2">
                                    <a
                                        href="/account"
                                        class:list={[
                                            'rounded px-2 py-1.5 text-xs',
                                            activeNav === 'account'
                                                ? 'bg-slate-800 text-slate-100'
                                                : 'text-slate-300 hover:bg-slate-800 hover:text-slate-100',
                                        ]}
                                        title="Account"
                                    >
                                        {user.username}
                                    </a>
                                    <form method="POST" action="/api/auth/logout" class="m-0">
                                        <button
                                            type="submit"
                                            class="rounded px-2 py-1.5 text-xs text-slate-500 hover:bg-slate-800 hover:text-slate-100"
                                            title="Sign out"
                                        >
                                            Sign out
                                        </button>
                                    </form>
                                </div>
                            </nav>
                        ) : null
                    }
                </div>
            </header>

            <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-8">
                <slot />
            </main>

            <footer class="mx-auto max-w-6xl px-6 py-8 text-xs text-slate-600">
                © {new Date().getFullYear()} CoreForge — Conveyor Filters
            </footer>
        </div>
    </body>
</html>
