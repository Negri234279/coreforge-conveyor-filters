---
import '../styles/global.css'

interface Props {
    title?: string
    activeNav?: 'home' | 'new'
}

const { title = 'CoreForge — Conveyor Filters', activeNav = 'home' } = Astro.props
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body
        class="min-h-full bg-[#0d1117] font-sans text-slate-200 antialiased"
        style="font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif"
    >
        <div class="flex min-h-screen flex-col">
            <header
                class="sticky top-0 z-30 border-b border-slate-800/80 bg-[#0d1117]/95 backdrop-blur"
            >
                <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
                    <a
                        href="/"
                        class="flex items-center gap-2 text-sm font-bold tracking-[0.18em] text-slate-100 uppercase"
                    >
                        <span
                            class="inline-block h-2 w-2 rounded-full bg-teal-400 shadow-[0_0_10px_rgba(45,212,191,0.7)]"
                        ></span>
                        CoreForge
                        <span class="text-xs font-normal tracking-normal text-slate-400 normal-case"
                            >· Conveyor Filters</span
                        >
                    </a>
                    <nav class="flex items-center gap-1 text-sm">
                        <a
                            href="/"
                            class:list={[
                                'rounded px-3 py-1.5',
                                activeNav === 'home'
                                    ? 'bg-slate-800 text-slate-100'
                                    : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                            ]}>My Conveyors</a
                        >
                        <a
                            href="/filters/new"
                            class:list={[
                                'rounded px-3 py-1.5 font-semibold',
                                activeNav === 'new'
                                    ? 'bg-teal-500/90 text-slate-950'
                                    : 'bg-teal-500/80 text-slate-950 hover:bg-teal-400',
                            ]}>+ New Filter</a
                        >
                    </nav>
                </div>
            </header>

            <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-8">
                <slot />
            </main>

            <footer class="mx-auto max-w-6xl px-6 py-8 text-xs text-slate-600">
                © {new Date().getFullYear()} CoreForge — Conveyor Filters
            </footer>
        </div>
    </body>
</html>
