---
import '../styles/global.css'
import { version as APP_VERSION } from '../../package.json'

interface Props {
    title?: string
    /** Meta description / OG description for this page. */
    description?: string
    /** OG/Twitter preview image, resolved against the site origin. */
    image?: string
    /** Set true on pages that shouldn't be indexed (auth, account…). */
    noindex?: boolean
    activeNav?: 'home' | 'new' | 'org' | 'orgFilters' | 'account'
    /** Hide the nav (used on the auth pages). */
    hideNav?: boolean
}

const SITE_NAME = 'CoreForge — Conveyor Filters'
const DEFAULT_DESCRIPTION =
    'Design, organise and share Rust industrial conveyor filter presets. Build presets in your browser and copy/paste the exact JSON the game expects.'

const {
    title = SITE_NAME,
    description = DEFAULT_DESCRIPTION,
    image = '/og-image.png',
    noindex = false,
    activeNav = 'home',
    hideNav = false,
} = Astro.props

// Astro.site is set in astro.config.mjs; fall back to the request origin in dev.
const siteOrigin = Astro.site ?? new URL(Astro.url.origin)
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin)
const ogImageUrl = new URL(image, siteOrigin)
const user = Astro.locals.user
// Only the bits the UI needs — keeps the email server-side.
const clientUser = user
    ? {
          id: user.id,
          username: user.username,
          orgId: user.orgId ?? null,
          orgRole: user.orgRole ?? null,
      }
    : null
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl.href} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}
        <meta name="theme-color" content="#0d1117" />
        <meta name="app-version" content={APP_VERSION} />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content={SITE_NAME} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalUrl.href} />
        <meta property="og:image" content={ogImageUrl.href} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:locale" content="en" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl.href} />

        <script is:inline define:vars={{ clientUser, APP_VERSION }}>
            window.__cf_user = clientUser
            window.__cf_version = APP_VERSION
        </script>
    </head>
    <body
        class="min-h-full bg-[#0d1117] font-sans text-slate-200 antialiased"
        style="font-family: Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif"
    >
        <div class="flex min-h-screen flex-col">
            <header
                class="sticky top-0 z-30 border-b border-slate-800/80 bg-[#0d1117]/95 backdrop-blur"
            >
                <div
                    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 sm:py-4"
                >
                    <a
                        href={user ? '/' : '/login'}
                        class="flex min-w-0 items-center gap-2 text-sm font-bold tracking-[0.18em] text-slate-100 uppercase"
                    >
                        <span
                            class="inline-block h-2 w-2 shrink-0 rounded-full bg-teal-400 shadow-[0_0_10px_rgba(45,212,191,0.7)]"
                        ></span>
                        <span class="truncate">CoreForge</span>
                        <span
                            class="hidden truncate text-xs font-normal tracking-normal text-slate-400 normal-case sm:inline"
                            >· Conveyor Filters</span
                        >
                    </a>

                    {
                        !hideNav && user ? (
                            <>
                                <button
                                    type="button"
                                    id="nav-toggle"
                                    class="inline-flex items-center justify-center rounded p-2 text-slate-300 hover:bg-slate-800 hover:text-slate-100 md:hidden"
                                    aria-controls="primary-nav"
                                    aria-expanded="false"
                                    aria-label="Toggle navigation"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="h-6 w-6"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            d="M4 6h16M4 12h16M4 18h16"
                                        />
                                    </svg>
                                </button>

                                <nav
                                    id="primary-nav"
                                    class="absolute inset-x-0 top-full hidden flex-col gap-1 border-b border-slate-800/80 bg-[#0d1117]/98 px-4 py-3 text-sm backdrop-blur md:static md:flex md:flex-row md:flex-wrap md:items-center md:gap-1 md:border-0 md:bg-transparent md:p-0 md:backdrop-blur-0"
                                >
                                    <a
                                        href="/"
                                        class:list={[
                                            'rounded px-3 py-2 md:py-1.5',
                                            activeNav === 'home'
                                                ? 'bg-slate-800 text-slate-100'
                                                : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                                        ]}
                                    >
                                        My Conveyors
                                    </a>
                                    <a
                                        href="/org/filters"
                                        class:list={[
                                            'rounded px-3 py-2 md:py-1.5',
                                            activeNav === 'orgFilters'
                                                ? 'bg-slate-800 text-slate-100'
                                                : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                                        ]}
                                    >
                                        Clan Filters
                                    </a>
                                    <a
                                        href="/org"
                                        class:list={[
                                            'rounded px-3 py-2 md:py-1.5',
                                            activeNav === 'org'
                                                ? 'bg-slate-800 text-slate-100'
                                                : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                                        ]}
                                    >
                                        Clan
                                    </a>
                                    <a
                                        href="/filters/new"
                                        class:list={[
                                            'rounded px-3 py-2 font-semibold md:py-1.5',
                                            activeNav === 'new'
                                                ? 'bg-teal-500/90 text-slate-950'
                                                : 'bg-teal-500/80 text-slate-950 hover:bg-teal-400',
                                        ]}
                                    >
                                        + New Filter
                                    </a>
                                    <div class="mt-2 flex items-center gap-2 border-t border-slate-800 pt-2 md:mt-0 md:ml-2 md:border-t-0 md:border-l md:pt-0 md:pl-2">
                                        <a
                                            href="/account"
                                            class:list={[
                                                'rounded px-3 py-2 text-xs md:px-2 md:py-1.5',
                                                activeNav === 'account'
                                                    ? 'bg-slate-800 text-slate-100'
                                                    : 'text-slate-300 hover:bg-slate-800 hover:text-slate-100',
                                            ]}
                                            title="Account"
                                        >
                                            {user.username}
                                        </a>
                                        <form method="POST" action="/api/auth/logout" class="m-0">
                                            <button
                                                type="submit"
                                                class="rounded px-3 py-2 text-xs text-slate-500 hover:bg-slate-800 hover:text-slate-100 md:px-2 md:py-1.5"
                                                title="Sign out"
                                            >
                                                Sign out
                                            </button>
                                        </form>
                                    </div>
                                </nav>
                            </>
                        ) : null
                    }
                </div>
            </header>

            <script>
                const toggle = document.getElementById('nav-toggle')
                const nav = document.getElementById('primary-nav')
                if (toggle && nav) {
                    toggle.addEventListener('click', () => {
                        const open = nav.classList.toggle('hidden') === false
                        nav.classList.toggle('flex', open)
                        toggle.setAttribute('aria-expanded', open ? 'true' : 'false')
                    })
                }
            </script>

            <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-8">
                <slot />
            </main>

            <footer class="mx-auto max-w-6xl px-6 py-8 text-xs text-slate-600">
                © {new Date().getFullYear()} CoreForge — Conveyor Filters
                <span class="text-slate-700" title="App version">· v{APP_VERSION}</span>
            </footer>
        </div>
    </body>
</html>
