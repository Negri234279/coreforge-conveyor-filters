---
import Layout from '../layouts/Layout.astro'

// Public page — listed in PUBLIC_PAGES in src/middleware.ts so it's reachable
// without an account (privacy/cookies disclosure must be visible to anyone).

const LAST_UPDATED = '2026-05-14'
const CONTACT_EMAIL = 'rafalejo01@gmail.com'
const OPERATOR = 'negri234279'
---

<Layout title="Legal – CoreForge" noindex hideNav={!Astro.locals.user}>
    <article
        class="prose-legal mx-auto max-w-3xl space-y-10 text-sm leading-relaxed text-slate-300"
    >
        <header>
            <h1 class="text-2xl font-bold tracking-tight text-slate-100">Legal</h1>
            <p class="mt-2 text-xs text-slate-500">Last updated: {LAST_UPDATED}</p>
            <nav class="mt-4 flex flex-wrap gap-3 text-xs">
                <a href="#legal-notice" class="text-teal-300 hover:underline">Legal Notice</a>
                <span class="text-slate-700">·</span>
                <a href="#privacy" class="text-teal-300 hover:underline">Privacy Policy</a>
                <span class="text-slate-700">·</span>
                <a href="#cookies" class="text-teal-300 hover:underline">Cookies Policy</a>
            </nav>
        </header>

        {/* ----------------- Legal Notice ----------------- */}
        <section id="legal-notice" class="scroll-mt-24 space-y-3">
            <h2 class="text-lg font-semibold text-slate-100">1. Legal Notice</h2>
            <p>
                CoreForge — Conveyor Filters (the "Service") is a non-commercial, hobby web
                application that lets players of the game <em>Rust</em> design, organise and share industrial
                conveyor filter presets. The Service does not sell anything, does not run ads, and is
                not affiliated with or endorsed by Facepunch Studios or the publishers of <em
                    >Rust</em
                >.
            </p>
            <p>
                The Service is operated on a personal, non-professional basis by
                <strong class="text-slate-100">{OPERATOR}</strong>. For any legal, privacy or
                takedown enquiry you can reach the operator at
                <a class="text-teal-300 hover:underline" href={`mailto:${CONTACT_EMAIL}`}>
                    {CONTACT_EMAIL}
                </a>.
            </p>
            <p>
                <em>Rust</em>, all game item names, icons and references belong to their respective
                owners and are used here under nominative fair use, only to identify the items the
                Service helps players configure. No game assets are redistributed.
            </p>
            <p>
                All source code and content authored by the operator is provided "as is", with no
                warranty of any kind. The Service may change, be temporarily unavailable, or be
                discontinued at any time without notice.
            </p>
            <p>
                Spanish law and the courts of the operator's place of residence apply for any
                dispute that cannot be resolved by amicable means.
            </p>
        </section>

        {/* ----------------- Privacy ----------------- */}
        <section id="privacy" class="scroll-mt-24 space-y-3">
            <h2 class="text-lg font-semibold text-slate-100">2. Privacy Policy</h2>
            <p>
                The Service is run as a hobby project and is designed around the principle of
                <strong class="text-slate-100">data minimisation</strong>. It does not run
                analytics, does not embed third-party trackers, does not show ads, and
                <strong class="text-slate-100"> never sells, rents or shares</strong> your data with anyone.
            </p>

            <h3 class="mt-4 text-base font-semibold text-slate-200">What is stored</h3>
            <ul class="ml-5 list-disc space-y-1">
                <li>
                    <strong>Account data:</strong> your chosen username (required), an Argon2id hash of
                    your password (the plain password is never stored), and an optional email address
                    if you provide one at registration.
                </li>
                <li>
                    <strong>Content you create:</strong> the categories, subcategories, filters, Open
                    Cores and items you build inside the app. This is the whole point of the Service —
                    without it there would be nothing to save.
                </li>
                <li>
                    <strong>Clan membership:</strong> if you join or create a clan, your account is linked
                    to that clan (with a role: owner / admin / member).
                </li>
                <li>
                    <strong>Technical metadata:</strong> account creation timestamp, a
                    <code class="rounded bg-slate-800/80 px-1 py-0.5 text-[11px]">
                        last_seen_at
                    </code>
                    timestamp updated on authenticated requests (used to compute aggregate active-user
                    counts), and a usage-event log of in-app actions you take (logins, content create/delete,
                    clones of clan-shared content, JSON exports). Event records are used only by the operator
                    to understand whether the Service is being used and to spot problems; they are not
                    exposed to other users.
                </li>
                <li>
                    <strong>Session token:</strong> a SHA-256 hash of your session token is stored server-side
                    so you stay logged in. The raw token only lives in your browser cookie (see Cookies
                    Policy below).
                </li>
            </ul>

            <h3 class="mt-4 text-base font-semibold text-slate-200">What is NOT stored</h3>
            <ul class="ml-5 list-disc space-y-1">
                <li>
                    No precise IP address logs are kept beyond the transient memory used for
                    rate-limiting login/registration attempts (anti brute-force only).
                </li>
                <li>No browser fingerprint, no device ID, no geolocation.</li>
                <li>
                    No third-party analytics (no Google Analytics, no Plausible, no Sentry public
                    token, no Cloudflare Web Analytics, etc.).
                </li>
                <li>No advertising cookies. There are no ads.</li>
            </ul>

            <h3 class="mt-4 text-base font-semibold text-slate-200">Legal basis (GDPR / RGPD)</h3>
            <ul class="ml-5 list-disc space-y-1">
                <li>
                    <strong>Contract performance (Art. 6.1.b GDPR):</strong> the data above is the bare
                    minimum needed to provide you with the Service you signed up for.
                </li>
                <li>
                    <strong>Legitimate interest (Art. 6.1.f GDPR):</strong> the usage-event log and aggregate
                    active-user counts are used by the operator to keep the Service healthy and to decide
                    whether to keep maintaining it. The data is not shared with third parties.
                </li>
            </ul>

            <h3 class="mt-4 text-base font-semibold text-slate-200">Retention</h3>
            <p>
                Your account data and content are kept for as long as your account exists. Sessions
                are kept for at most 30 days from the last renewal. If you ask the operator to
                delete your account, all the rows associated with you in the database (account,
                content, events, sessions) are removed.
            </p>

            <h3 class="mt-4 text-base font-semibold text-slate-200">Hosting and transfers</h3>
            <p>
                Data is stored in a single database file on a server controlled by the operator.
                There is no third-party data processor. Where possible the server is located inside
                the European Economic Area; in any case, there are no international transfers of
                personal data to entities outside it.
            </p>

            <h3 class="mt-4 text-base font-semibold text-slate-200">Your rights</h3>
            <p>
                Under GDPR / LOPDGDD you can ask the operator to access, rectify, port or delete
                your data, or to restrict its processing, by emailing
                <a class="text-teal-300 hover:underline" href={`mailto:${CONTACT_EMAIL}`}>
                    {CONTACT_EMAIL}
                </a>. You can also lodge a complaint with the Spanish Data Protection Agency (<a
                    class="text-teal-300 hover:underline"
                    href="https://www.aepd.es"
                    rel="noopener nofollow"
                    target="_blank">aepd.es</a
                >) if you believe your rights have been infringed.
            </p>

            <h3 class="mt-4 text-base font-semibold text-slate-200">Children</h3>
            <p>
                The Service is not directed at children under 14. If you believe a minor has created
                an account, email the operator and the account will be removed.
            </p>
        </section>

        {/* ----------------- Cookies ----------------- */}
        <section id="cookies" class="scroll-mt-24 space-y-3">
            <h2 class="text-lg font-semibold text-slate-100">3. Cookies Policy</h2>
            <p>
                The Service uses cookies <strong class="text-slate-100"
                    >only for technical / functional purposes</strong
                > — to keep you signed in. There are no analytics cookies, no advertising cookies, and
                no third-party cookies. Under Spanish and EU cookie rules, strictly necessary cookies
                do not require prior consent, which is why you do not see a cookie banner.
            </p>

            <div class="overflow-x-auto">
                <table class="mt-3 w-full text-left text-xs">
                    <thead class="text-[11px] tracking-wider text-slate-500 uppercase">
                        <tr class="border-b border-slate-800">
                            <th class="py-2 pr-3">Name</th>
                            <th class="py-2 pr-3">Purpose</th>
                            <th class="py-2 pr-3">Duration</th>
                            <th class="py-2">Type</th>
                        </tr>
                    </thead>
                    <tbody class="text-slate-300">
                        <tr class="border-b border-slate-800/60">
                            <td class="py-2 pr-3 font-mono text-slate-200">cf_session</td>
                            <td class="py-2 pr-3">
                                Keeps your session active so you don't have to log in on every page.
                                HttpOnly, SameSite=Lax, Secure in production.
                            </td>
                            <td class="py-2 pr-3">Up to 30 days (sliding renewal)</td>
                            <td class="py-2">First-party, strictly necessary</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <p class="mt-3">
                You can delete this cookie at any time from your browser settings (this will log you
                out). The Service stores small pieces of state in your browser's
                <code class="rounded bg-slate-800/80 px-1 py-0.5 text-[11px]">localStorage</code>
                (theme preference, recently used items, draft data); this is not a cookie and is never
                transmitted to the server.
            </p>
        </section>

        <footer class="border-t border-slate-800 pt-4 text-xs text-slate-500">
            <p>
                Questions? Email
                <a class="text-teal-300 hover:underline" href={`mailto:${CONTACT_EMAIL}`}>
                    {CONTACT_EMAIL}
                </a>.
            </p>
        </footer>
    </article>
</Layout>
