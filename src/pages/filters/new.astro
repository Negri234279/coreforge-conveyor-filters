---
import Layout from '../../layouts/Layout.astro'
import FilterForm from '../../components/FilterForm'
---

<Layout title="New Filter – CoreForge" activeNav="new">
    <div class="mb-8">
        <a
            href="/"
            class="text-xs font-semibold tracking-wider text-slate-500 uppercase hover:text-slate-200"
            >&larr; Back to My Conveyors</a
        >
        <h1 class="mt-2 text-2xl font-bold tracking-tight text-slate-100">Create Filter</h1>
        <p class="mt-1 text-sm text-slate-400">
            Build a conveyor preset by picking a cover, a destination box, and the items it should
            pass.
        </p>
    </div>

    <div class="rounded-lg border border-slate-800 bg-slate-900/30 p-6 shadow-inner">
        <FilterForm client:only="preact" />
    </div>
</Layout>
