---
import Layout from '../../../layouts/Layout.astro'
import OrgOpenCoreDetail from '../../../components/OrgOpenCoreDetail'
import CopyToast from '../../../components/CopyToast'

const user = Astro.locals.user!
const { id } = Astro.params
if (!id) return Astro.redirect('/org/filters')
if (!user.orgId) return Astro.redirect('/org')
---

<Layout title="Clan Open Core – CoreForge" activeNav="orgFilters">
    <OrgOpenCoreDetail client:only="preact" openCoreId={id} />
    <CopyToast client:only="preact" />
</Layout>
