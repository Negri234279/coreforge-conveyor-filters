---
import Layout from '../../../../../layouts/Layout.astro'
import OrgFilterIsland from '../../../../../components/OrgFilterIsland'

const user = Astro.locals.user!
const { id } = Astro.params
if (!id) return Astro.redirect('/org/filters')
if (!user.orgId) return Astro.redirect('/org')
if (user.orgRole !== 'owner' && user.orgRole !== 'admin')
    return Astro.redirect(`/org/opencore/${id}`)

const url = new URL(Astro.request.url)
const categoryId = url.searchParams.get('categoryId') ?? undefined
const subcategoryId = url.searchParams.get('subcategoryId') ?? undefined
if (!categoryId) return Astro.redirect(`/org/opencore/${id}`)
---

<Layout title="New Clan Filter – CoreForge" activeNav="orgFilters">
    <div class="mb-8">
        <a
            href={`/org/opencore/${id}`}
            class="text-xs font-semibold tracking-wider text-slate-500 uppercase transition-colors hover:text-amber-400"
            >&larr; Back to Open Core</a
        >
        <h1
            class="mt-2 text-3xl text-slate-100"
            style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em"
        >
            New Clan Filter
        </h1>
        <p class="mt-1 text-sm text-slate-400">Create a new filter in the shared Open Core.</p>
    </div>

    <div class="rounded-lg border border-slate-800 bg-slate-900/30 p-6 shadow-inner">
        <OrgFilterIsland
            client:only="preact"
            openCoreId={id}
            categoryId={categoryId}
            subcategoryId={subcategoryId}
        />
    </div>
</Layout>
