---
import Layout from '../../layouts/Layout.astro'
import OrgFiltersList from '../../components/OrgFiltersList'
import ClanOpenCoresList from '../../components/ClanOpenCoresList'
import ClanCategoriesList from '../../components/ClanCategoriesList'

const user = Astro.locals.user!
---

<Layout title="Clan Filters – CoreForge" activeNav="orgFilters">
    <div class="mb-8 flex items-end justify-between gap-3">
        <div>
            <h1
                class="text-3xl text-slate-100"
                style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em"
            >
                Clan Filters
            </h1>
            <p class="mt-1 text-sm text-slate-400">
                Open Cores and filters that members of your clan have chosen to share. Read-only —
                clone any to your own space.
            </p>
        </div>
        <a
            href="/org"
            class="rounded border border-slate-800 bg-slate-900/60 px-3 py-2 text-sm font-semibold text-slate-200 transition-colors hover:border-amber-500/40 hover:text-amber-400"
        >
            Clan settings
        </a>
    </div>

    {
        !user.orgId ? (
            <div class="rounded-lg border border-dashed border-slate-800 bg-slate-900/30 p-10 text-center">
                <p class="text-sm text-slate-400">You're not in a clan yet.</p>
                <p class="mt-1 text-xs text-slate-500">
                    <a
                        href="/org"
                        class="text-amber-400 underline decoration-amber-400/40 transition-colors hover:text-amber-300 hover:decoration-amber-400"
                    >
                        Create one or join with an invite code.
                    </a>
                </p>
            </div>
        ) : (
            <div class="space-y-10">
                <section>
                    <h2 class="mb-3 font-mono text-[10px] font-semibold tracking-widest text-slate-400 uppercase">
                        Shared Open Cores
                    </h2>
                    <ClanOpenCoresList client:only="preact" />
                </section>
                <section>
                    <h2 class="mb-3 font-mono text-[10px] font-semibold tracking-widest text-slate-400 uppercase">
                        Shared categories
                    </h2>
                    <ClanCategoriesList client:only="preact" />
                </section>
                <section>
                    <h2 class="mb-3 font-mono text-[10px] font-semibold tracking-widest text-slate-400 uppercase">
                        Shared filters
                    </h2>
                    <OrgFiltersList client:only="preact" />
                </section>
            </div>
        )
    }
</Layout>
