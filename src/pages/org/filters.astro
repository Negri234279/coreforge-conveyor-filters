---
import Layout from '../../layouts/Layout.astro'
import OrgFiltersList from '../../components/OrgFiltersList'
import ClanOpenCoresList from '../../components/ClanOpenCoresList'
import CopyToast from '../../components/CopyToast'

const user = Astro.locals.user!
---

<Layout title="Clan Filters – CoreForge" activeNav="orgFilters">
    <div class="mb-8 flex items-end justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-slate-100">Clan Filters</h1>
            <p class="mt-1 text-sm text-slate-400">
                Open Cores and filters that members of your clan have chosen to share. Read-only —
                clone any to your own space.
            </p>
        </div>
        <a
            href="/org"
            class="rounded-md border border-slate-700 bg-slate-900/60 px-3 py-2 text-sm font-semibold text-slate-200 hover:border-teal-500/60 hover:text-teal-200"
        >
            Clan settings
        </a>
    </div>

    {
        !user.orgId ? (
            <div class="rounded-lg border border-dashed border-slate-800 bg-slate-900/30 p-10 text-center">
                <p class="text-sm text-slate-300">You're not in a clan yet.</p>
                <p class="mt-1 text-xs text-slate-500">
                    <a href="/org" class="text-teal-300 hover:underline">
                        Create one or join with an invite code.
                    </a>
                </p>
            </div>
        ) : (
            <div class="space-y-10">
                <section>
                    <h2 class="mb-3 text-xs font-semibold tracking-wider text-slate-400 uppercase">
                        Shared Open Cores
                    </h2>
                    <ClanOpenCoresList client:only="preact" />
                </section>
                <section>
                    <h2 class="mb-3 text-xs font-semibold tracking-wider text-slate-400 uppercase">
                        Shared filters
                    </h2>
                    <OrgFiltersList client:only="preact" />
                </section>
            </div>
        )
    }

    <CopyToast client:only="preact" />
</Layout>
