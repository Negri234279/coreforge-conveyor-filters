---
import Layout from '../../layouts/Layout.astro'
import DeleteClanButton from '../../components/DeleteClanButton'
import { db, schema } from '../../db/client'
import { eq } from 'drizzle-orm'

const user = Astro.locals.user!

const url = new URL(Astro.request.url)
const error = url.searchParams.get('error')

let org: typeof schema.organizations.$inferSelect | null = null
let members: { id: string; username: string; orgRole: string | null }[] = []
if (user.orgId) {
    org =
        db
            .select()
            .from(schema.organizations)
            .where(eq(schema.organizations.id, user.orgId))
            .get() ?? null
    members = db
        .select({
            id: schema.users.id,
            username: schema.users.username,
            orgRole: schema.users.orgRole,
        })
        .from(schema.users)
        .where(eq(schema.users.orgId, user.orgId))
        .all()
}

const isOwner = user.orgRole === 'owner'
---

<Layout title="Clan – CoreForge" activeNav="org">
    {
        error ? (
            <div class="mb-4 rounded border border-rose-500/40 bg-rose-500/10 px-3 py-2 text-sm text-rose-200">
                {error}
            </div>
        ) : null
    }

    {
        !org ? (
            <div class="grid gap-6 md:grid-cols-2">
                <section class="rounded-lg border border-slate-800 bg-slate-900/30 p-5">
                    <h2 class="text-lg font-semibold text-slate-100">Create a clan</h2>
                    <p class="mt-1 text-sm text-slate-400">
                        Start a new clan. You'll be the owner and get an invite code to share.
                    </p>
                    <form method="POST" action="/api/org/create" class="mt-4 flex gap-2">
                        <input
                            name="name"
                            type="text"
                            required
                            minlength="2"
                            maxlength="48"
                            placeholder="Clan name"
                            class="flex-1 rounded border border-slate-800 bg-slate-900/60 px-3 py-2 text-sm text-slate-100 outline-none transition-colors focus:border-amber-500/40 focus:ring-1 focus:ring-amber-500/20"
                        />
                        <button
                            type="submit"
                            class="rounded bg-amber-500 px-4 py-2 text-sm font-bold uppercase tracking-wide text-slate-950 transition-colors hover:bg-amber-400"
                        >
                            Create
                        </button>
                    </form>
                </section>

                <section class="rounded-lg border border-slate-800 bg-slate-900/30 p-5">
                    <h2 class="text-lg font-semibold text-slate-100">Join with invite code</h2>
                    <p class="mt-1 text-sm text-slate-400">
                        Got an invite from a clan owner? Drop the code below.
                    </p>
                    <form method="POST" action="/api/org/join" class="mt-4 flex gap-2">
                        <input
                            name="code"
                            type="text"
                            required
                            minlength="6"
                            maxlength="20"
                            autocapitalize="characters"
                            autocorrect="off"
                            spellcheck="false"
                            placeholder="Invite code"
                            class="flex-1 rounded border border-slate-800 bg-slate-900/60 px-3 py-2 font-mono text-sm tracking-wider text-slate-100 uppercase outline-none transition-colors focus:border-amber-500/40 focus:ring-1 focus:ring-amber-500/20"
                        />
                        <button
                            type="submit"
                            class="rounded border border-slate-800 bg-slate-900/60 px-4 py-2 text-sm font-semibold text-slate-200 transition-colors hover:border-amber-500/40 hover:text-amber-400"
                        >
                            Join
                        </button>
                    </form>
                </section>
            </div>
        ) : (
            <div class="space-y-6">
                <header class="flex flex-wrap items-end justify-between gap-3">
                    <div>
                        <p class="text-xs font-semibold tracking-wider text-slate-500 uppercase">
                            Your clan
                        </p>
                        <h1
                            class="mt-1 text-3xl text-slate-100"
                            style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em"
                        >
                            {org.name}
                        </h1>
                        <p class="mt-1 text-sm text-slate-400">
                            {members.length} {members.length === 1 ? 'member' : 'members'} · You are{' '}
                            <span class="text-amber-400">{user.orgRole}</span>.
                        </p>
                    </div>
                    <a
                        href="/org/filters"
                        class="rounded border border-slate-800 bg-slate-900/60 px-3 py-2 text-sm font-semibold text-slate-200 transition-colors hover:border-amber-500/40 hover:text-amber-400"
                    >
                        View shared filters →
                    </a>
                </header>

                {isOwner ? (
                    <section class="rounded-lg border border-slate-800 bg-slate-900/30 p-5">
                        <h2 class="font-mono text-[10px] font-semibold tracking-widest text-slate-400 uppercase">
                            Invite code
                        </h2>
                        <p class="mt-1 text-xs text-slate-500">
                            Share this code with anyone you want to add. Rotating it invalidates the
                            old one.
                        </p>
                        <div class="mt-3 flex flex-wrap items-center gap-3">
                            <code class="rounded border border-slate-800 bg-slate-950/80 px-3 py-2 font-mono text-base tracking-[0.2em] text-amber-400">
                                {org.inviteCode}
                            </code>
                            <form method="POST" action="/api/org/invite/rotate" class="m-0">
                                <button
                                    type="submit"
                                    class="rounded border border-slate-800 bg-slate-900/60 px-3 py-2 text-sm font-semibold text-slate-200 transition-colors hover:border-amber-500/40 hover:text-amber-400"
                                >
                                    Rotate code
                                </button>
                            </form>
                        </div>
                    </section>
                ) : null}

                <section class="rounded-lg border border-slate-800 bg-slate-900/30 p-5">
                    <h2 class="font-mono text-[10px] font-semibold tracking-widest text-slate-400 uppercase">
                        Members
                    </h2>
                    {isOwner ? (
                        <p class="mt-1 text-xs text-slate-500">
                            As the owner you can promote members to <em>admin</em> or demote them
                            back to <em>member</em>.
                        </p>
                    ) : null}
                    <ul class="mt-3 divide-y divide-slate-800">
                        {members.map((m) => {
                            const isSelf = m.id === user.id
                            const canEdit = isOwner && !isSelf && m.orgRole !== 'owner'
                            return (
                                <li class="flex items-center justify-between gap-3 py-2">
                                    <span class="text-sm text-slate-200">
                                        {m.username}
                                        {isSelf ? (
                                            <span class="ml-2 text-xs text-slate-500">(you)</span>
                                        ) : null}
                                    </span>
                                    {canEdit ? (
                                        <form
                                            method="POST"
                                            action="/api/org/members/role"
                                            class="m-0 flex items-center gap-2"
                                            data-role-form
                                        >
                                            <input type="hidden" name="userId" value={m.id} />
                                            <select
                                                name="role"
                                                class="rounded border border-slate-800 bg-slate-900/60 px-2 py-1 text-xs text-slate-100 uppercase outline-none transition-colors focus:border-amber-500/40 focus:ring-1 focus:ring-amber-500/20"
                                                aria-label={`Role for ${m.username}`}
                                            >
                                                <option
                                                    value="admin"
                                                    selected={m.orgRole === 'admin'}
                                                >
                                                    Admin
                                                </option>
                                                <option
                                                    value="member"
                                                    selected={m.orgRole !== 'admin'}
                                                >
                                                    Member
                                                </option>
                                            </select>
                                            <noscript>
                                                <button
                                                    type="submit"
                                                    class="rounded border border-slate-800 bg-slate-900/60 px-2 py-1 text-xs font-semibold text-slate-200 transition-colors hover:border-amber-500/40 hover:text-amber-400"
                                                >
                                                    Save
                                                </button>
                                            </noscript>
                                        </form>
                                    ) : (
                                        <span class="text-xs text-slate-500 uppercase">
                                            {m.orgRole}
                                        </span>
                                    )}
                                </li>
                            )
                        })}
                    </ul>
                </section>

                <script>
                    // Auto-submit role changes so the owner doesn't need a Save button.
                    for (const form of document.querySelectorAll('form[data-role-form]')) {
                        const select = form.querySelector('select[name="role"]')
                        if (!select) continue
                        select.addEventListener('change', () => {
                            ;(form as HTMLFormElement).submit()
                        })
                    }
                </script>

                <section class="rounded-lg border border-rose-900/40 bg-rose-950/20 p-5">
                    <h2 class="text-sm font-semibold tracking-wider text-rose-300 uppercase">
                        Danger zone
                    </h2>
                    {isOwner ? (
                        <DeleteClanButton clanName={org.name} client:only="preact" />
                    ) : (
                        <form method="POST" action="/api/org/leave" class="mt-3">
                            <button
                                type="submit"
                                class="rounded border border-rose-500/50 bg-rose-500/10 px-3 py-2 text-sm font-semibold text-rose-200 transition-colors hover:bg-rose-500/20"
                            >
                                Leave clan
                            </button>
                        </form>
                    )}
                </section>
            </div>
        )
    }
</Layout>
