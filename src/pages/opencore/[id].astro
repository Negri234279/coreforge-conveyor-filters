---
import Layout from '../../layouts/Layout.astro'
import OpenCoreDetail from '../../components/OpenCoreDetail'

const { id } = Astro.params
if (!id) return Astro.redirect('/')
---

<Layout title="Open Core – CoreForge" activeNav="home">
    <OpenCoreDetail client:only="preact" openCoreId={id} />
</Layout>
