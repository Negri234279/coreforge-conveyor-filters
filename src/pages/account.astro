---
import Layout from '../layouts/Layout.astro'

const user = Astro.locals.user!
---

<Layout title="Account – CoreForge" activeNav="account">
    <div class="mx-auto max-w-xl space-y-6">
        <header>
            <h1 class="text-2xl font-bold tracking-tight text-slate-100">Account</h1>
            <p class="mt-1 text-sm text-slate-400">
                Signed in as <span class="text-slate-200">{user.username}</span>.
            </p>
        </header>

        <section class="rounded-lg border border-slate-800 bg-slate-900/30 p-5">
            <h2 class="text-sm font-semibold tracking-wider text-slate-300 uppercase">Profile</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Username</dt>
                    <dd class="text-slate-200">{user.username}</dd>
                </div>
                <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Email</dt>
                    <dd class="text-slate-200">
                        {user.email ?? <span class="text-slate-600">— not set —</span>}
                    </dd>
                </div>
                <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Clan</dt>
                    <dd class="text-slate-200">
                        {
                            user.orgId ? (
                                <a href="/org" class="text-teal-300 hover:underline">
                                    {user.orgRole}
                                </a>
                            ) : (
                                <a href="/org" class="text-teal-300 hover:underline">
                                    Not in a clan
                                </a>
                            )
                        }
                    </dd>
                </div>
            </dl>
        </section>

        <section class="rounded-lg border border-slate-800 bg-slate-900/30 p-5">
            <h2 class="text-sm font-semibold tracking-wider text-slate-300 uppercase">Session</h2>
            <form method="POST" action="/api/auth/logout" class="mt-3">
                <button
                    type="submit"
                    class="rounded-md border border-slate-700 bg-slate-900/60 px-3 py-2 text-sm font-semibold text-slate-200 hover:border-teal-500/60 hover:text-teal-200"
                >
                    Sign out
                </button>
            </form>
        </section>
    </div>
</Layout>
