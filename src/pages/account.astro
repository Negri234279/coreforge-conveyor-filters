---
import Layout from '../layouts/Layout.astro'

const user = Astro.locals.user!
---

<Layout title="Account – CoreForge" noindex activeNav="account">
    <div class="mx-auto max-w-xl space-y-6">
        <header class="mb-8">
            <div class="mb-0.5 font-mono text-[11px] uppercase tracking-widest text-amber-500/50">
                Command Center
            </div>
            <h1
                class="text-4xl text-slate-100"
                style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em"
            >
                Account
            </h1>
            <p class="mt-2 text-sm text-slate-400">
                Signed in as <span class="text-slate-200">{user.username}</span>.
            </p>
        </header>

        <section
            class="rounded-lg border border-slate-800 bg-slate-900/30 p-5 transition-all hover:border-amber-500/40 hover:shadow-[0_0_20px_rgba(245,158,11,0.08)]"
        >
            <h2 class="font-mono text-[11px] uppercase tracking-widest text-slate-400">Profile</h2>
            <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Username</dt>
                    <dd class="text-slate-200">{user.username}</dd>
                </div>
                <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Email</dt>
                    <dd class="text-slate-200">
                        {user.email ?? <span class="text-slate-600">— not set —</span>}
                    </dd>
                </div>
                <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Clan</dt>
                    <dd class="text-slate-200">
                        {
                            user.orgId ? (
                                <a
                                    href="/org"
                                    class="text-amber-400 transition-colors hover:text-amber-300"
                                >
                                    {user.orgRole}
                                </a>
                            ) : (
                                <a
                                    href="/org"
                                    class="text-amber-400 transition-colors hover:text-amber-300"
                                >
                                    Not in a clan
                                </a>
                            )
                        }
                    </dd>
                </div>
            </dl>
        </section>

        <section
            class="rounded-lg border border-slate-800 bg-slate-900/30 p-5 transition-all hover:border-amber-500/40 hover:shadow-[0_0_20px_rgba(245,158,11,0.08)]"
        >
            <h2 class="font-mono text-[11px] uppercase tracking-widest text-slate-400">Session</h2>
            <form method="POST" action="/api/auth/logout" class="mt-3">
                <button
                    type="submit"
                    class="rounded-md border border-slate-700 bg-slate-900/60 px-3 py-2 text-sm font-semibold text-slate-200 transition-all hover:border-amber-500/40 hover:bg-slate-800 hover:text-amber-400"
                >
                    Sign out
                </button>
            </form>
        </section>
    </div>
</Layout>
