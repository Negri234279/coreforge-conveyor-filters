---
import Layout from '../layouts/Layout.astro'
import AdminDashboard from '../components/AdminDashboard'

const user = Astro.locals.user!
// 404 (not 403) to non-admins so the route's existence stays implicit.
if (!user.isAdmin) {
    return new Response(null, { status: 404 })
}

// Optional deep-link to the SigNoz observability UI. Empty/unset = no button,
// so dev environments without SigNoz running stay clean. SigNoz has its own
// auth — clicking the link goes through SigNoz's /login if you don't have a
// session there yet.
const signozUrl = process.env.SIGNOZ_URL?.trim() || null
---

<Layout title="Admin – CoreForge" noindex activeNav="admin">
    <header class="mb-8">
        <div class="mb-0.5 font-mono text-[11px] tracking-widest text-amber-500/50 uppercase">
            Command Center
        </div>
        <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
                <h1
                    class="text-4xl text-slate-100"
                    style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em"
                >
                    Admin Dashboard
                </h1>
                <p class="mt-2 text-sm text-slate-400">App-wide metrics. Visible only to you.</p>
            </div>
            {
                signozUrl && (
                    <a
                        href={signozUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 rounded border border-slate-700 bg-slate-800/60 px-3 py-1.5 text-sm text-slate-200 transition-all hover:border-amber-500/40 hover:bg-slate-800 hover:text-amber-400"
                        title="Open SigNoz observability UI in a new tab"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-4 w-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M3 12h3l3-8 4 16 3-8h5"
                            />
                        </svg>
                        <span>SigNoz</span>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-3 w-3 opacity-60"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M14 3h7v7m0-7L10 14m-4-1H5a2 2 0 00-2 2v4a2 2 0 002 2h4a2 2 0 002-2v-1"
                            />
                        </svg>
                    </a>
                )
            }
        </div>
    </header>
    <AdminDashboard client:only="preact" />
</Layout>
