---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Not Found | CoreForge" noindex={true}>
    <div class="relative mx-auto max-w-md overflow-hidden pt-16 text-center">
        <!-- ambient glow -->
        <div
            class="pointer-events-none absolute -top-16 left-1/2 h-64 w-64 -translate-x-1/2 rounded-full opacity-40"
            style="background: radial-gradient(circle, rgba(245,158,11,0.10) 0%, transparent 68%)"
        >
        </div>

        <!-- eyebrow -->
        <p class="mb-3 font-mono text-[11px] uppercase tracking-widest text-amber-500/50">
            System Error
        </p>

        <!-- big 404 -->
        <div
            class="mb-2 text-slate-100/10 select-none"
            style="font-family:'Bebas Neue',sans-serif; font-size:clamp(6rem,24vw,10rem); line-height:1; letter-spacing:0.05em; text-shadow:0 0 80px rgba(245,158,11,0.15)"
        >
            404
        </div>

        <!-- title -->
        <h1
            class="mb-3 text-4xl text-slate-100"
            style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.05em"
        >
            Page Not Found
        </h1>

        <!-- description -->
        <p class="mx-auto max-w-xs text-sm leading-relaxed text-slate-400">
            That conveyor belt leads nowhere. The page you're looking for doesn't exist or has been
            moved.
        </p>

        <!-- divider -->
        <div class="my-8 h-px bg-slate-800"></div>

        <!-- CTA -->
        <a
            href="/"
            class="inline-block rounded bg-amber-500 px-5 py-2.5 text-sm font-bold uppercase tracking-wide text-slate-950 transition-colors hover:bg-amber-400"
        >
            Back to Command Center
        </a>
    </div>
</Layout>
