---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 — Not Found | CoreForge" noindex={true}>
    <div class="mx-auto max-w-md pt-12 text-center">
        <p class="mb-2 font-mono text-sm font-semibold tracking-widest text-red-400 uppercase">
            Error 404
        </p>
        <h1 class="text-2xl font-bold tracking-tight text-slate-100">Page not found</h1>
        <p class="mt-2 text-sm text-slate-400">
            That conveyor belt leads nowhere. The page you're looking for doesn't exist or has been
            moved.
        </p>
        <div class="mt-6 flex justify-center">
            <a
                href="/"
                class="inline-block rounded-md bg-teal-500/90 px-4 py-2 text-sm font-semibold text-slate-950 shadow hover:bg-teal-400"
            >
                Back to My Conveyors
            </a>
        </div>
    </div>
</Layout>
