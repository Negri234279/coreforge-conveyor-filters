{
    "name": "coreforge-conveyor-filters",
    "description": "Web app for designing and sharing Rust industrial conveyor filter presets",
    "type": "module",
    "version": "1.16.0",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "dev": "astro dev --host 127.0.0.1 --port 3000 --open",
        "dev:otel": "node --env-file=.env --import ./otel/instrumentation.mjs ./node_modules/astro/bin/astro.mjs dev --host 127.0.0.1 --port 3000 --open",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "dev:obs:up": "docker compose -f infra/dev/docker-compose.yml --env-file infra/dev/.env up -d",
        "dev:obs:down": "docker compose -f infra/dev/docker-compose.yml down",
        "dev:obs:logs": "docker compose -f infra/dev/docker-compose.yml logs -f",
        "staging:up": "docker compose -f infra/staging/docker-compose.yml --env-file infra/staging/.env up -d --build",
        "staging:down": "docker compose -f infra/staging/docker-compose.yml down",
        "staging:logs": "docker compose -f infra/staging/docker-compose.yml logs -f",
        "staging:rebuild": "docker compose -f infra/staging/docker-compose.yml --env-file infra/staging/.env up -d --build --force-recreate",
        "prod:obs:up": "docker compose -f infra/prod/docker-compose.yml --env-file infra/prod/.env up -d",
        "prod:obs:down": "docker compose -f infra/prod/docker-compose.yml down",
        "prod:obs:logs": "docker compose -f infra/prod/docker-compose.yml logs -f",
        "migrate": "node scripts/run-migration.mjs",
        "optimize-images": "node scripts/optimize-images.mjs"
    },
    "dependencies": {
        "@astrojs/node": "10.1.0",
        "@astrojs/preact": "5.1.2",
        "@node-rs/argon2": "2.0.2",
        "@opentelemetry/api": "1.9.1",
        "@opentelemetry/api-logs": "0.218.0",
        "@opentelemetry/auto-instrumentations-node": "0.76.0",
        "@opentelemetry/auto-instrumentations-web": "0.63.0",
        "@opentelemetry/context-zone": "2.7.1",
        "@opentelemetry/exporter-logs-otlp-grpc": "0.218.0",
        "@opentelemetry/exporter-logs-otlp-http": "0.218.0",
        "@opentelemetry/exporter-metrics-otlp-grpc": "0.218.0",
        "@opentelemetry/exporter-trace-otlp-grpc": "0.218.0",
        "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
        "@opentelemetry/instrumentation": "0.218.0",
        "@opentelemetry/resources": "2.7.1",
        "@opentelemetry/sdk-logs": "0.218.0",
        "@opentelemetry/sdk-metrics": "2.7.1",
        "@opentelemetry/sdk-node": "0.218.0",
        "@opentelemetry/sdk-trace-base": "2.7.1",
        "@opentelemetry/sdk-trace-web": "2.7.1",
        "@opentelemetry/semantic-conventions": "1.41.1",
        "@preact/signals": "2.9.0",
        "@tailwindcss/vite": "4.2.4",
        "arctic": "3.7.0",
        "astro": "^6.3.0",
        "better-sqlite3": "12.10.0",
        "drizzle-orm": "0.45.2",
        "nanoid": "5.1.11",
        "preact": "10.29.1",
        "tailwindcss": "4.2.4",
        "three": "0.171.0"
    },
    "devDependencies": {
        "@astrojs/check": "0.9.9",
        "@types/better-sqlite3": "7.6.13",
        "@types/node": "25.6.1",
        "@types/three": "0.171.0",
        "drizzle-kit": "0.31.10",
        "prettier": "3.8.3",
        "prettier-plugin-astro": "0.14.1",
        "prettier-plugin-tailwindcss": "0.8.0",
        "sharp": "0.34.5",
        "typescript": "6.0.3"
    }
}
